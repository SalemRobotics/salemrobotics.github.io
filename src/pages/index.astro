---
import Layout from "@/layouts/Layout.astro";

import fs from "node:fs";
import { Image, Picture } from "astro:assets";

import Schedule from "@/components/Schedule.astro";
import blue_devil_svg from "@assets/bluedevil.svg";
import logo_grayscale from "@assets/team_logo_grayscale.svg";
import about_us_image from "@assets/about_us.png";
import first_logo_light from "@assets/first/first_logo_light.png";
import first_logo_dark from "@assets/first/first_logo_dark.png";
import driveteam from "@assets/driveteam.png";
import fll_camp_field from "@assets/fll_camp_field.png";
import fll_camp_lab from "@assets/fll_camp_lab.png";
import salembration from "@assets/salembration.png";
import salem_scramble from "@assets/salem_scramble.png";
---

<Layout
  title="Salem Robotics"
  description="The official website for FRC team 6324."
  selected=""
>
  <section id="title-card">
    <div id="title-card-container">
      <h1 id="title-card-title" class="devil-bauer">FRC Team 6324</h1>
      <p id="title-card-desc" class="oswald-text">
        At team 6324 we aspire to promote STEM education, help build and grow
        robotics programs, and connect students and industry professionals in
        our community.
      </p>
    </div>
    <Image
      src={blue_devil_svg}
      alt="The Blue Devils' logo"
      id="title-card-logo"
      inferSize={true}
      format="svg"
      priority={true}
      aria-hidden="true"
    />
  </section>
  <section id="about-us">
    <Picture
      src={about_us_image}
      alt="A picture of the team at the 2025 Greater Boston District Event."
      formats={["avif", "webp"]}
      fallbackFormat="png"
      inferSize={true}
      priority={true}
      layout="constrained"
      id="about-us-picture"
    />
    <div id="about-us-container">
      <h2 id="about-us-header" class="oswald-text">About Us</h2>
      <p id="about-us-text" class="oswald-text">
        We are team 6324 from Salem, New Hampshire. Our rookie season was in
        2017, and from then on we have worked to create a welcoming environment
        for anyone who wants to join the team. Part of having a welcoming
        environment is being involved in the <em
          ><abbr>FIRST</abbr><sup>&reg;</sup></em
        > and local community. We value collaboration, gracious professionalism, and
        communication. One of our main goals for the members of the team is to prepare
        them for occupations in the science industry by practicing our values, as
        well as teaching them Scrum, graphic design and adobe, CAD and design, software
        development, public relations, outreach, and manufacturing.
      </p>
    </div>
  </section>
  <section id="first">
    <div id="first-desc-container">
      <div id="first-desc-text-container">
        <h2 id="first-desc-header" class="oswald-text"><em>FIRST</em></h2>
        <p id="first-desc-text" class="oswald-text">
          <em><abbr>FIRST</abbr></em> &nbsp; Robotics Competition (FRC) teams design,
          program, and build a robot starting with a standard kit of parts and common
          set of rules to play in a themed head-to-head challenge. Teams also build
          a brand, develop community partnerships for support, and work to promote
          STEM in their local community.
          <br />
          <br />
          <a href="https://firstinspires.org"
            >For more information on FIRST, click here</a
          >
        </p>
      </div>
      <Picture
        src={first_logo_light}
        alt="The official logo of FIRST"
        formats={["avif", "webp"]}
        fallbackFormat="png"
        inferSize={true}
        layout="constrained"
        class="first-logo"
        id="first-logo-light"
        aria-hidden="true"
      />
      <Picture
        src={first_logo_dark}
        alt="The official logo of FIRST"
        formats={["avif", "webp"]}
        fallbackFormat="png"
        inferSize={true}
        layout="constrained"
        class="first-logo"
        id="first-logo-dark"
        aria-hidden="true"
      />
    </div>
    <div id="first-images-container">
      <Picture
        src={driveteam}
        alt="A picture of our drive team at the New England District Championships"
        formats={["avif", "webp"]}
        fallbackFormat="png"
        inferSize={true}
        layout="constrained"
        id="first-driveteam-image"
      />
      <div id="game-video-container">
        <h3 id="game-video-header" class="oswald-text">
          This year's game video:
        </h3>
        <iframe
          width="100%"
          height="100%"
          src="https://www.youtube-nocookie.com/embed/_fybREErgyM?si=QiXlz7O0tmGGlJ3m"
          title="YouTube video player"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; fullscreen; gyroscope;"
          referrerpolicy="strict-origin-when-cross-origin"
          id="game-video"></iframe>
      </div>
    </div>
  </section>
  <section id="events">
    <div id="events-sched-info">
      <Schedule id="events-schedule" />
      <div id="events-planned-container">
        <h3 id="events-planned-header" class="oswald-text">
          Planned District Events
        </h3>
        <ul id="events-planned" class="oswald-text">
          <li>URI: March 20-21</li>
          <li>UNH: March 28-29</li>
          <li>New England DCMP: April 16-18</li>
        </ul>
      </div>
    </div>
    <div id="events-calendar-container">
      <iframe
        title="Team calendar"
        src="https://calendar.google.com/calendar/embed?src=ea85c994e6f57af1dcf4ee4034ac650009c357125bdb8d1c423e6e6e7a6041e0%40group.calendar.google.com&ctz=America%2FNew_York"
        style="border: 0"
        width="100%"
        height="100%"></iframe>
    </div>
  </section>
  <section id="outreach">
    <div id="outreach-desc-container">
      <div>
        <h2 id="outreach-desc-header" class="oswald-text">Outreach</h2>
        <div id="outreach-desc-text" class="oswald-text">
          <p>
            We host outreach events to promote STEM and FIRST values in our
            community, allowing us to show what we do, and attract new team
            members and community partners. Previously, we have attended events
            such as:
          </p>
          <ul id="outreach-events-list">
            <li>Salem Scramble</li>
            <li>Salembration</li>
            <li>Our FLL summer camp</li>
            <li>Salem Holiday Parade</li>
            <li>Cars, Robots & Coffee</li>
            <li>Woodbury Olympics</li>
          </ul>
        </div>
      </div>
      <Picture
        src={salem_scramble}
        alt="The team demoing at the Salem Scramble event"
        formats={["avif", "webp"]}
        fallbackFormat="png"
        inferSize={true}
        layout="constrained"
        id="outreach-salem-scramble-image"
      />
    </div>
    <div id="outreach-images">
      <Picture
        src={salembration}
        alt="The team demoing at Salem's 275th anniversary celebration"
        formats={["avif", "webp"]}
        fallbackFormat="png"
        inferSize={true}
        layout="constrained"
        id="outreach-salembration-image"
      />
      <Picture
        src={fll_camp_field}
        alt="Students of our FLL summer camp testing their robots on a field"
        formats={["avif", "webp"]}
        fallbackFormat="png"
        inferSize={true}
        layout="constrained"
        id="outreach-fll-camp-field-image"
      />
    </div>
    <div id="outreach-fll">
      <Picture
        src={fll_camp_lab}
        alt="Students of our FLL summer camp working on their robots"
        formats={["avif", "webp"]}
        fallbackFormat="png"
        inferSize={true}
        layout="constrained"
        id="outreach-fll-camp-lab-image"
      />
      <div id="outreach-fll-container">
        <h3 id="outreach-fll-header" class="oswald-text">FLL summer camp</h3>
        <p id="outreach-fll-text" class="oswald-text">
          FIRST Lego League Summer Camp is a community outreach event that
          allows us to get involved with elementary level students and introduce
          them to STEM.
        </p>
      </div>
    </div>
  </section>
  <style is:inline>
    html {
      scroll-behavior: smooth;
    }

    #title-card {
      position: relative;
      width: 100%;
      height: 75vh;
      display: flex;
      flex-direction: row;
      flex-wrap: nowrap;
      overflow: hidden;

      & #title-card-container {
        width: 70vw;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
      }

      & #title-card-title {
        font-size: 4.5rem;
        text-align: center;
      }

      & #title-card-desc {
        width: 75%;
        font-size: 1.5rem;
      }

      & #title-card-logo {
        position: absolute;
        top: 0;
        right: 0;
        width: 50vw;
        height: auto;
        transform: translate(30%, -15%);
      }

      @media (max-width: 600px) {
        height: fit-content;
        justify-content: center;

        & #title-card-title {
          width: 90vw;
          font-size: 2.5rem;
        }

        & #title-card-desc {
          width: 90vw;
          font-size: 1.2rem;
        }

        & #title-card-logo {
          display: none;
        }
      }
    }

    #about-us {
      display: flex;
      flex-direction: row;
      justify-content: space-around;

      & #about-us-picture {
        width: 50vw;
        height: auto;
        border-radius: 5px;
      }

      & #about-us-container {
        width: 40vw;
      }

      & #about-us-header {
        width: 100%;
        text-align: center;
        font-size: 2rem;
      }

      & #about-us-text {
        font-size: 1.125rem;
      }

      @media (max-width: 600px) {
        flex-direction: column;
        width: 100%;
        height: fit-content;

        align-items: center;

        & #about-us-picture {
          width: 95vw;
        }

        & #about-us-container {
          width: 90vw;
        }
      }
    }

    #first {
      display: flex;
      flex-direction: row;
      justify-content: space-around;
      height: 80vh;

      & #first-desc-container,
      & #first-desc-text-container {
        width: 45vw;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-around;
        align-content: center;
      }

      & #first-desc-header {
        font-size: 5rem;
      }

      & #first-desc-text {
        font-size: 1.25rem;
        font-weight: 400;
      }

      & .first-logo {
        width: 30vw;
        height: auto;
      }

      & #first-images-container {
        width: 40vw;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        align-items: center;
      }

      & #first-driveteam-image {
        width: 30vw;
        height: auto;
        transform: translateY(-2.5%);
        border-radius: 5px;
      }

      & #game-video-container {
        width: 30vw;
        height: auto;
      }

      & #game-video-header {
        font-size: 1.25rem;
      }

      & #game-video {
        border: none;
        border-radius: 5px;
      }

      @media (max-width: 600px) {
        flex-direction: column;
        align-items: center;
        height: fit-content;

        & #first-desc-text-container {
          height: fit-content;
          width: 90vw;
        }

        & #first-desc-header {
          font-size: 2rem;
          text-align: center;
          margin-block: 0;
        }

        & #first-desc-container {
          width: 95vw;
          height: fit-content;
          justify-content: normal;
          align-items: center;
        }

        & #first-images-container {
          display: none;
        }

        & .first-logo {
          width: 87.5vw;
        }
      }

      @media (max-width: 450px) {
        & .first-logo {
          width: 95vw;
        }
      }
    }

    @media (prefers-color-scheme: light) {
      #first-logo-dark {
        display: none;
      }
    }

    @media (prefers-color-scheme: dark) {
      #first-logo-light {
        display: none;
      }
    }

    #events {
      margin-top: 12.5vh;
      display: flex;
      flex-direction: row-reverse;
      justify-content: space-evenly;

      & #events-sched-info {
        width: 35vw;
        display: flex;
        flex-direction: column;
        justify-content: space-around;
      }

      & #events-planned-container {
        width: 100%;
      }

      & #events-planned-header {
        width: 100%;
        text-align: center;
        font-size: 1.75rem;
        font-weight: 600;
      }

      & #events-planned {
        font-size: 1.125rem;
        font-weight: 600;
      }

      & #events-calendar-container {
        width: 50vw;
        height: 70vh;
      }

      @media (max-width: 600px) {
        flex-direction: column;
        align-items: center;
        margin-top: 0;

        & #events-sched-info {
          width: 90vw;
          align-items: center;
        }

        & #events-schedule {
          width: 80vw;
        }

        & #events-planned-container {
          width: 90vw;
        }

        & #events-calendar-container {
          width: 100vw;
          height: 100vw;
        }
      }
    }

    #outreach {
      margin-top: 5vh;
      display: flex;
      flex-direction: row-reverse;
      justify-content: space-evenly;

      & #outreach-desc-container {
        width: 30vw;
        display: flex;
        flex-direction: column;
      }

      & #outreach-desc-header {
        font-size: 1.75rem;
        transform: translateX(-1.5vw);
      }

      & #outreach-desc-text {
        font-size: 1.125rem;
      }

      & #outreach-events-list {
        list-style: none;
      }
      & #outreach-events-list li::before {
        content: "- ";
      }

      & #outreach-salem-scramble-image {
        width: 25vw;
        height: auto;
      }

      & #outreach-images {
        display: flex;
        flex-direction: column;
        justify-content: space-evenly;
        align-items: center;
        width: 25vw;
      }

      & #outreach-salembration-image {
        width: 20vw;
        height: 20vw;
        object-fit: cover;
        object-position: center;
        border-radius: 50%;
        transform: translate(-5vw, 3vh);
      }

      & #outreach-fll-camp-field-image {
        width: 15vw;
        height: 15vw;
        object-fit: cover;
        object-position: center;
        border-radius: 100%;
        transform: translateX(2.5vw);
      }

      & #outreach-fll {
        width: 30vw;
        display: flex;
        flex-direction: column;
        justify-content: space-evenly;
      }

      & #outreach-fll-camp-lab-image {
        width: 27.5vw;
        height: auto;
      }

      & #outreach-fll-header {
        font-size: 1.75rem;
      }

      & #outreach-fll-text {
        font-size: 1.125rem;
        transform: translateX(1.5vw);
      }

      @media (max-width: 600px) {
        flex-direction: column;
        align-items: center;

        & #outreach-desc-container {
          width: 90vw;
          align-items: center;
          flex-direction: column-reverse;
        }

        & #outreach-desc-header {
          transform: none;
          width: 90vw;
          text-align: center;
        }

        & #outreach-salem-scramble-image {
          width: 90vw;
        }

        & #outreach-images {
          width: 80vw;
          height: fit-content;

          margin-bottom: -10vh;
        }

        & #outreach-salembration-image {
          width: 50vw;
          height: 50vw;
          transform: translateX(-10vw);
        }

        & #outreach-fll-camp-field-image {
          width: 30vw;
          height: 30vw;
          transform: translate(10vw, -10vh);
        }

        & #outreach-fll {
          flex-direction: column-reverse;
          width: 90vw;
          align-items: center;
        }

        & #outreach-fll-header {
          text-align: center;
        }

        & #outreach-fll-camp-lab-image {
          width: 90vw;
        }
      }
    }
  </style>
</Layout>
