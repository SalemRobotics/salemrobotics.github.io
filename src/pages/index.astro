---
import Layout from '@/layouts/Layout.astro';

import fs from "node:fs";
import { Image, Picture } from "astro:assets";

import Schedule from "@/components/Schedule.astro";
import blue_devil_svg from "@assets/bluedevil.svg";
import logo_grayscale from "@assets/team_logo_grayscale.svg";
import about_us_image from "@assets/about_us.png";
import first_logo_light from "@assets/first/first_logo_light.png";
import first_logo_dark from "@assets/first/first_logo_dark.png";
import driveteam from "@assets/driveteam.png";
import fll_camp_field from "@assets/fll_camp_field.png";
import fll_camp_lab from "@assets/fll_camp_lab.png";
import salembration from "@assets/salembration.png";
import salem_scramble from "@assets/salem_scramble.png";
---

<Layout title="Salem Robotics" description="" selected="" fetches={[{ url: "https://fonts.googleapis.com/css2?family=Oswald:wght@200..700&display=swap", rel: "stylesheet" }]} headerless={true}>
	<header id="navbar">
		<nav>
			<div id="navbar-title">
				<h1 class="devil-bauer">
					The Blue Devils
				</h1>
			</div>
			<ul id="navbar-links">
				<li><a href="#outreach" class="oswald-text">Outreach</a></li>
				<li><a href="#updates" class="oswald-text">Updates</a></li>
				<li><a href="#resources" class="oswald-text">Resources</a></li>
				<li><a href="#support-us" class="oswald-text">Support Us</a></li>
			</ul>
		</nav>
	</header>
	<section id="title-card">
		<div id="title-card-container">
			<h1 id="title-card-title" class="devil-bauer">FRC Team 6324</h1>
			<p id="title-card-desc" class="oswald-text">
                At team 6324 we aspire to promote STEM education help build and grow robotics programs, and connect
				students and industry professionals in our community.
			</p>
		</div>
		<Image src={blue_devil_svg} alt="The Blue Devils' logo" id="title-card-logo" aria-hidden="true" />
	</section>
	<section id="about-us">
		<Picture 
				src={about_us_image}
				alt="A picture of the team at the 2025 Greater Boston District Event."
				formats={["avif", "webp"]}
				fallbackFormat="png"
				inferSize={true}
				layout="constrained"
				id="about-us-picture"
		/>
		<div id="about-us-container">
			<h2 id="about-us-header" class="devil-bauer">About Us</h2>
			<p id="about-us-text" class="oswald-text">
				We are team 6324 from Salem, New Hampshire. Our rookie season was in 2017, and from then on we have
				worked to create a welcoming environment for anyone who wants to join the team. Part of having a
				welcoming environment is being involved in the <em><abbr>FIRST</abbr><sup>&reg;</sup></em> and local
				community. We value collaboration, gracious professionalism, and communication. One of our main goals
				for the members of the team is to prepare them for occupations in the science industry by practicing our
				values, as well as teaching them Scrum, graphic design and adobe, CAD and design, software development,
				public relations, outreach, and manufacturing.
			</p>
		</div>
	</section>
	<section id="first">
		<div id="first-desc-container">
			<div>
				<h2 id="first-desc-header" class="roboto-text"><em>FIRST</em></h2>
				<p id="first-desc-text" class="oswald-text">
					<em><abbr>FIRST</abbr></em> Robotics Competition (FRC) teams design, program, and
					build a robot starting with a standard kit of parts and common set of rules to play in a themed
					head-to-head challenge. Teams also build a brand, develop community partnerships for support, and
					work to promote STEM in their local community.
					<br />
					<br />
					For more information on FIRST, click <a href="https://firstinspires.org">here</a>
				</p>
			</div>
			<Picture
				src={first_logo_light}
				alt="The official logo of FIRST"
				formats={["avif", "webp"]}
				fallbackFormat="png"
				inferSize={true}
				layout="full-width"
				class="first-logo"
				id="first-logo-light"
				aria-hidden="true"
			/>
			<Picture
				src={first_logo_dark}
				alt="The official logo of FIRST"
				formats={["avif", "webp"]}
				fallbackFormat="png"
				inferSize={true}
				layout="full-width"
				class="first-logo"
				id="first-logo-dark"
				aria-hidden="true"
			/>
		</div>
		<div id="first-images-container">
			<Picture
				src={driveteam}
				alt="A picture of our drive team at the New England District Championships"
				formats={["avif", "webp"]}
				fallbackFormat="png"
				inferSize={true}
				layout="constrained"
				id="first-driveteam-image"
				/>
			<div id="game-video-container">
				<h3 id="game-video-header" class="oswald-text">This year's game video:</h3>
            	<iframe width="100%" height="100%" src="https://www.youtube-nocookie.com/embed/_fybREErgyM?si=QiXlz7O0tmGGlJ3m" title="YouTube video player" allow="accelerometer; autoplay; clipboard-write; encrypted-media; fullscreen; gyroscope;" referrerpolicy="strict-origin-when-cross-origin" id="game-video"/>
			</div>
		</div>
	</section>
	<section id="events">
		<div id="events-sched-info">
			<Schedule id="events-schedule"/>
			<div id="events-planned-container">
				<h3 id="events-planned-header" class="oswald-text">Planned District Events</h3>
				<ul id="events-planned" class="oswald-text">
					<li>URI: March 20-21</li>
					<li>UNH: March 28-29</li>
					<li>New England DCMP: April 16-18</li>
				</ul>
			</div>
		</div>
		<div id="events-calendar-container">
            <iframe src="https://calendar.google.com/calendar/embed?src=6da6819b6a706700984680c5424a3fb0e200bdf3d1829157f34c24c9a98d7ce0%40group.calendar.google.com&ctz=America%2FNew_York" style="border: 0" width="100%" height="100%" />
		</div>
	</section>
	<section id="outreach">
		<div id="outreach-desc-container">
			<h2 id="outreach-desc-header" class="oswald-text">Outreach</h2>
			<div id="outreach-desc-text" class="oswald-text">
				<p>
					We host outreach events to promote STEM and FIRST values in our community, allowing us to show what
					we do, and attract new team members and community partners. Previously, we have attended events such
					as:
				</p>
				<ul id="outreach-events-list">
					<li>Salem Scramble</li>
					<li>Salembration</li>
					<li>Our FLL summer camp</li>
					<li>Salem Holiday Parade</li>
					<li>Cars, Robots & Coffee</li>
					<li>Woodbury Olympics</li>
				</ul>
			</div>
			<Picture src={salem_scramble} alt="" id="outreach-salem-scramble-image" />
		</div>
		<div id="outreach-images">
			<Picture src={salembration} alt="" id="outreach-salembration-image" />
			<Picture src={fll_camp_field} alt="" id="outreach-fll-camp-field-image" />
		</div>
		<div id="outreach-fll">
			<Picture src={fll_camp_lab} alt="" id="outreach-fll-camp-lab-image" />
			<div id="outreach-fll-container">
				<h3 id="outreach-fll-header" class="oswald-text">FLL summer camp</h3>
				<p id="outreach-fll-text" class="oswald-text">
					FIRST Lego League Summer Camp is a community outreach event that allows us to get involved with
					elementary level students and introduce them to STEM.
				</p>
			</div>
		</div>
	</section>
