	<style is:inline>
		html {
			scroll-behavior: smooth;
		}

		#navbar {
			width: 100%;
			background-color: #656565;
			color: var(--text);

			& > nav {
                width: 100%;
                display: flex;
                flex-direction: row;
			}

			& #navbar-title {
				width: 30%;
				color: var(--bd-color);

				& > h1 {
					width: 100%;
					text-align: center;
				}
			}

			& #navbar-links {
                width: 70%;
                display: flex;
                justify-content: space-around;
                flex-direction: row;
                list-style: none;

				& li {
					display: flex;
					align-items: center;

					& > a {
						font-size: 1.8rem;
						font-weight: 600;

                        color: var(--text);
                        text-decoration: none;
					}
				}
			}
		}

		#title-card {
			position: relative;
			width: 100%;
			height: 75vh;
			display: flex;
			flex-direction: row;
			flex-wrap: nowrap;
			overflow: hidden;

			& #title-card-container {
				width: 70vw;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
			}
			& #title-card-title {
				font-size: 4.5rem;
			}

			& #title-card-desc {
				width: 75%;
				font-size: 1.5rem;
			}

			& #title-card-logo {
				position: absolute;
				top: 0;
				right: 0;
				width: 50vw;
				height: auto;
				transform: translate(30%, -15%);
			}
		}

		#about-us {
			display: flex;
			flex-direction: row;
			justify-content: space-around;

			& #about-us-picture {
				width: 50vw;
				height: auto;
				border-radius: 5px;
			}

			& #about-us-container {
				width: 40vw;
			}

			& #about-us-header {
				width: 100%;
				text-align: center;
				font-size: 2rem;
			}

			& #about-us-text {
				font-size: 1.125rem;
			}
		}

		#first {
			display: flex;
			flex-direction: row;
			justify-content: space-around;
			height: 80vh;

			& #first-desc-container {
				width: 45vw;
				height: 100%;
				display: flex;
				flex-direction: column;
				justify-content: space-around;
				align-content: center;
			}

			& #first-desc-header {
				font-size: 5rem;
			}

			& #first-desc-text {
				font-size: 1.25rem;
				font-weight: 400;
			}

			& .first-logo {
				width: 30vw;
				height: auto;
			}

            & #first-images-container {
                width: 40vw;
				display: flex;
				flex-direction: column;
				justify-content: space-between;
				align-items: center;
            }

			& #first-driveteam-image {
				width: 30vw;
				height: auto;
				transform: translateY(-5vh);
				border-radius: 5px;
			}

			& #game-video-container {
				width: 30vw;
				height: auto;
			}

			& #game-video-header {
				font-size: 1.25rem;
			}

			& #game-video {
                border: none;
				border-radius: 5px;
            }
		}

		@media (prefers-color-scheme: light) {
			#first-logo-dark {
				display: none;
			}
		}

		@media (prefers-color-scheme: dark) {
			#first-logo-light {
				display: none;
			}
		}

		#events {
			margin-top: 12.5vh;
			display: flex;
			flex-direction: row-reverse;
			justify-content: space-evenly;

			& #events-sched-info {
				width: 35vw;
				display: flex;
				flex-direction: column;
				justify-content: space-around;
			}

			& #events-planned-container {
				width: 100%;
			}

			& #events-planned-header {
				width: 100%;
				text-align: center;
				font-size: 1.75rem;
				font-weight: 600;
			}

			& #events-planned {
				font-size: 1.125rem;
				font-weight: 600;
			}

			& #events-calendar-container {
				width: 50vw;
				height: 70vh;
			}
		}

		#outreach {
			margin-top: 5vh;
			display: flex;
			flex-direction: row-reverse;
			justify-content: space-evenly;

			& #outreach-desc-container {
				width: 30vw;
			}

			& #outreach-desc-header {
				font-size: 1.75rem;
				transform: translateX(-1.5vw);
			}

			& #outreach-desc-text {
				font-size: 1.125rem;
			}

			& #outreach-events-list {
				list-style: none;
			}
			& #outreach-events-list li::before {
				content: "- ";
			}

			& #outreach-salem-scramble-image {
				width: 25vw;
				height: auto;
			}

			& #outreach-images {
				display: flex;
				flex-direction: column;
				justify-content: space-evenly;
				align-items: center;
				width: 25vw;
			}

			& #outreach-salembration-image {
				width: 20vw;
				height: 20vw;
				object-fit: cover;
				object-position: center;
				border-radius: 50%;
				transform: translate(-5vw, 3vh);
			}

			& #outreach-fll-camp-field-image {
				width: 15vw;
				height: 15vw;
				object-fit: cover;
				object-position: center;
				border-radius: 100%;
				transform: translateX(2.5vw);
			}

			& #outreach-fll {
				width: 30vw;
				display: flex;
				flex-direction: column;
				justify-content: space-evenly;
			}

			& #outreach-fll-camp-lab-image {
				width: 27.5vw;
				height: auto;
			}

			& #outreach-fll-container {

			}

			& #outreach-fll-header {
				font-size: 1.75rem;
			}

			& #outreach-fll-text {
				font-size: 1.125rem;
				transform: translateX(1.5vw);
			}
		}

		#leadership {

		}

		#sponsors-list {

		}

		#donations {

		}

		#updates {

		}

		#footer {
			background-color: #545454;
			min-height: 50vh;
			color: black;

			& #footer-top {
                width: 100%;

				& h2 {
					padding-block: 2.5vh;
					font-size: 2rem;
					width: 100%;
					text-align: center;
				}
