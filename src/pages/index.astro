	<!--	</div>-->
	<!--</section>-->
	<footer id="footer">
		<div id="footer-top">
			<h2 class="devil-bauer">Contact Us</h2>
		</div>
		<div id="footer-bottom">
			<div id="footer-logo-container">
				<Image src={logo_grayscale} alt="" inferSize={true} id="footer-logo"/>
			</div>
			<div id="footer-contact" class="oswald-text">
				<div id="contacts-email">
					<p><a href="mailto:john.seeman@nhsau57.org">john.seeman@nhsau57.org</a></p>
					<p><a href="mailto:brennan.macaig@gmail.com">brennan.macaig@gmail.com</a></p>
					<p><a href="mailto:friendsofshsrobotics@gmail.com">friendsofshsrobotics@gmail.com</a></p>
				</div>
				<div id="footer-links">
					<!-- Instagram Logo -->
					<a href="https://www.facebook.com/salemrobotics">
						<svg width="800px" height="800px" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path fill-rule="evenodd" clip-rule="evenodd" d="M12 18C15.3137 18 18 15.3137 18 12C18 8.68629 15.3137 6 12 6C8.68629 6 6 8.68629 6 12C6 15.3137 8.68629 18 12 18ZM12 16C14.2091 16 16 14.2091 16 12C16 9.79086 14.2091 8 12 8C9.79086 8 8 9.79086 8 12C8 14.2091 9.79086 16 12 16Z" fill="white"/>
